# Variante B — Cloudflare Tunnel. A VM não expõe 80/443; o cloudflared faz a
# conexão de saída e entrega em http://caddy:80. Sem TLS aqui (o Cloudflare cuida
# na borda). Renomeie para `Caddyfile` (ou monte este no lugar) ao usar a Variante B.

:80 {
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
