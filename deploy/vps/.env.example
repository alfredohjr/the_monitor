# Copie para deploy/vps/.env (NÃO versionado) e preencha com valores reais.
# Este arquivo é lido pelo Compose E injetado no backend via `env_file`.

# Postgres
POSTGRES_USER=appuser
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=appdb

# Domínio servido pelo Caddy (Variante A)
DOMAIN=seudominio.com

# URL pública do frontend. É a base do link de verificação de e-mail — sem ela o
# backend cai no default (http://localhost:3000) e o link chega inútil pro usuário.
FRONTEND_URL=https://seudominio.com

# Chave que assina os JWT. SEM ELA o backend usa o default público que está no
# repositório, e qualquer um consegue forjar token de qualquer usuário (#191).
# Gere com:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Login com Google (o mesmo Client ID do Google Cloud Console usado no front).
GOOGLE_CLIENT_ID=

# Hora (0-23) do envio do resumo diário de metas.
EMAIL_HORA=7

# Envio de e-mail (verificação de cadastro e resumo diário). SEM SMTP_HOST o
# backend só loga o link e o usuário que se cadastrar com e-mail fica preso no
# 403 "E-mail não verificado" — em produção, preencha. Qualquer provedor que
# fale SMTP serve (Brevo, Resend, SES, Postmark...).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remetente. Se vazio, cai no SMTP_USER.
SMTP_FROM=
# STARTTLS (porta 587). Só desligue em SMTP interno sem TLS.
SMTP_TLS=true

# Nota: APP_VERSION não entra aqui — vem carimbada na imagem do GHCR pelo CI
# (build-arg a partir da tag), então /version reflete o patch realmente rodando.

# Variante B (Cloudflare Tunnel) — token do túnel do Zero Trust
# TUNNEL_TOKEN=coloque-o-token-aqui
