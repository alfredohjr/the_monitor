# true em desenvolvimento, false (ou omitir) em produção
DEBUG=true

POSTGRES_USER=monitor
POSTGRES_PASSWORD=
POSTGRES_DB=monitor_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://monitor:senha@db:5432/monitor_db

NEXT_PUBLIC_API_URL=http://backend:8000

# Login com Google (issue #16). Crie um OAuth Client ID no Google Cloud Console.
# O mesmo Client ID vai nos dois (backend valida o token, frontend renderiza o botão).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Envio de e-mail (verificação de cadastro e resumo diário).
# SEM SMTP_HOST o backend só LOGA o link de verificação — é o default de dev, e
# deixa o link acessível no log do servidor. Preencha para enviar de verdade;
# qualquer provedor que fale SMTP serve (Brevo, Resend, SES, Postmark...).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remetente. Se vazio, cai no SMTP_USER.
SMTP_FROM=
# STARTTLS (porta 587). Só desligue em SMTP interno sem TLS.
SMTP_TLS=true

# URL pública do frontend — base do link de verificação de e-mail. Em produção
# aponte para o domínio real; sem isso o link chega apontando para localhost.
FRONTEND_URL=http://localhost:3000

# Chave que assina os JWT. Sem ela o backend usa um default público que está no
# repositório (#191). Gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Hora (0-23) do envio do resumo diário de metas.
EMAIL_HORA=7
